---
import Default from '@astrojs/starlight/components/PageTitle.astro';
import Ads from './Ads.astro';
---

{/* 1. 広告をページの一番上（タイトルの上）に配置 */}
<div class="top-ad-wrapper">
  <Ads type="horizontal" />
</div>

{/* 2. その後にStarlight標準のタイトルを表示 */}
<Default {...Astro.props}><slot /></Default>

<style>
  .top-ad-wrapper {
    /* タイトルとの間に少しだけ隙間を作る（Wiki風の余裕） */
    margin-bottom: 1.5rem;
    display: flex;
    justify-content: center;
    width: 100%;
  }
</style>
